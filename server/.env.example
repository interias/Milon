# Backend (FastAPI) - Secrets & Konfiguration
# Kopiere zu server/.env und trage echte Werte ein (wird NICHT committed).

# --- Datenbank (lokal, SQLite) ---
DATABASE_URL=sqlite:///./data/tracker.db

# --- LLM-Coach: OpenRouter (OpenAI-kompatibel) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# --- Phase 2: automatische Syncs (jetzt noch leer lassen) ---
HEVY_API_KEY=
FDDB_USER=
FDDB_PW=
FDDB_COOKIE=
FDDB_PHPSESSID=

# --- Health Connect: taeglicher Auto-Pull der Export-Zip aus Google Drive ---
# "Jeder mit dem Link"-Dateien sind per anonymem API-Key NICHT erreichbar (Google blockt das),
# der keylose Download per DATEI-ID funktioniert aber. So einrichten:
#   1) In Drive Rechtsklick auf "Health Connect.zip" -> Teilen -> "Jeder mit dem Link" (Leser)
#   2) "Link kopieren" -> aus https://drive.google.com/file/d/<ID>/view die <ID> hier eintragen
#      (ein voller Link wird auch akzeptiert).
HC_DRIVE_FILE_ID=
# Optional/Legacy (nur fuer einen WIRKLICH oeffentlichen Ordner per API-Key nutzbar):
GOOGLE_API_KEY=
HC_DRIVE_FOLDER_ID=
HC_DRIVE_FILENAME=Health Connect.zip
